<div class={{@class}}>
  <div class='label'>
    {{@label}}
  </div>
  <div class='checkbox-container'>
    <div>
      <input
        type='checkbox'
        id='checkboxId'
        checked={{this.value}}
        {{on 'change' this.onChange}}
      />
      <label for='checkboxId'>{{@option.label}}</label>
    </div>
  </div>
</div>